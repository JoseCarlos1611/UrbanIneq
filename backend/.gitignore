# IECA is downloaded automatically by Docker data-init
IECA/*
!IECA/.gitkeep

# Keep INE files tracked by default.
# Do not ignore INE unless the pipeline downloads/recreates it.

# Generated results
results/*
!results/.gitkeep

# OSRM / OSM
*.osm.pbf
*.osrm
*.osrm.*

# Temporaries
.DS_Store
Thumbs.db
*~
*.swp
*.swo
__pycache__/
*.pyc
.Rhistory
.RData
.Rproj.user/
node_modules/
