# Simular datos con muchos ceros
set.seed(123)  # Fijar la semilla para reproducibilidad
n <- 200  # Número de observaciones
x <- rnorm(n)  # Simular un predictor X
y <- rpois(n, lambda = exp(-1 + 1 * x))  # Generar conteos basados en X
y[y > 0] <- 0  # Introducir muchos ceros
# Ajustar un modelo GAM
gam_model <- gam(y ~ s(x), family = poisson)
# Resumen del modelo para interpretación
summary(gam_model)
# Gráfico ilustrativo: Ajuste del modelo GAM
plot(gam_model, main = "Modelo Aditivo Generalizado (GAM)")
# Simular datos binarios
set.seed(123)  # Fijar la semilla para reproducibilidad
n <- 100  # Número de observaciones
x <- rnorm(n)  # Simular un predictor X
prob <- 1 / (1 + exp(-1 - 2 * x))  # Generar probabilidades usando la función logística
y <- rbinom(n, 1, prob)  # Generar valores binarios de Y en función de las probabilidades
# Ajustar un modelo de regresión logística
logistic_model <- glm(y ~ x, family = binomial)
# Resumen del modelo para interpretación
summary(logistic_model)
# Gráfico ilustrativo: Probabilidades predichas
plot(x, y, main = "Regresión Logística", xlab = "Predictor X", ylab = "Probabilidad Y", pch = 19)
curve(1 / (1 + exp(-coef(logistic_model)[1] - coef(logistic_model)[2] * x)), add = TRUE, col = "blue", lwd = 2)
# Cargar el conjunto de datos iris
data(iris)
# Construir el árbol de clasificación
# Usamos la variable Species como la clase que queremos predecir y todas las demás variables como predictoras
arbol_modelo <- rpart(Species ~ ., data=iris, method="class")
# Resumen del modelo
print(arbol_modelo)
# Plotear el árbol
plot(arbol_modelo)
text(arbol_modelo, use.n=TRUE, all=TRUE, cex=.8)
