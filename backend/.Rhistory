# Simular datos jerárquicos
set.seed(123)  # Fijar la semilla para reproducibilidad
n_groups <- 10  # Número de grupos
n_per_group <- 20  # Número de observaciones por grupo
group <- factor(rep(1:n_groups, each = n_per_group))  # Variable de grupo
x <- rnorm(n_groups * n_per_group)  # Simular un predictor X
y <- rbinom(n_groups * n_per_group, 1, plogis(0.5 * x + 0.5 * as.numeric(group)))  # Generar datos binarios
# Ajustar un modelo GLMM
glmm_model <- glmer(y ~ x + (1 | group), family = binomial)
# Predicciones del modelo
pred <- predict(glmm_model, type = "response", re.form = NULL)
# Gráfico ilustrativo: Probabilidades predichas por grupo
plot(x, y, main = "GLMM: Predicciones por Grupo", xlab = "Predictor X", ylab = "Probabilidad Predicha", pch = 19)
points(x, pred, col = "blue", pch = 20)
abline(h = 0.5, lty = 2, col = "red")
