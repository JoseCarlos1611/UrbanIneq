# Simular datos de conteo
set.seed(123)
n <- 100
x <- rnorm(n, mean = 5, sd = 2)
y <- rpois(n, lambda = exp(0.3 * x))
# Ajustar un modelo de regresión Poisson
poisson_model <- glm(y ~ x, family = poisson)
# Resumen del modelo para interpretación
summary(poisson_model)
# Gráfico ilustrativo: Datos y ajuste del modelo
plot(x, y, main = "Regresión Poisson", xlab = "Predictor X", ylab = "Conteo Y", pch = 19)
lines(sort(x), fitted(poisson_model)[order(x)], col = "red", lwd = 2)
